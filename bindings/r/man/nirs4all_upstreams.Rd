\name{nirs4all_upstreams}
\alias{nirs4all_upstreams}
\title{List nirs4all upstream bindings}
\usage{
nirs4all_upstreams()
}
\value{
A data frame with upstream keys, availability flags, candidate package names,
and roles.
}
\description{
Returns the upstream binding registry used by the R aggregate package.
}
